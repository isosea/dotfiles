// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "format_on_save": "on",
  "markdown_preview": {
    "max_width": 1200.0,
  },
  "tabs": {
    "git_status": true,
  },
  "agent_ui_font_size": 12.0,
  "agent": {
    "terminal_init_command": "claude",
    "dock": "right",
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "model": "opus[1m]",
        "mode": "auto",
      },
      "type": "registry",
    },
  },
  "git_panel": {
    "dock": "left",
  },
  "terminal": {
    "font_family": "HackGen35 Console NF",
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
  },
  "autosave": "on_focus_change",
  "buffer_font_family": "HackGen35",
  "tab_size": 2,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "languages": {
    "Ruby": {
      // ruby-lsp だけを起動する。"..." を付けないことで、solargraph /
      // rubocop / fuzzy-ruby-server / kanayago など拡張が抱える他の
      // デフォルトサーバーは一切起動しない。
      // rubocop の診断/整形は ruby-lsp 内蔵の rubocop アドオンが担当する。
      "language_servers": ["ruby-lsp"],
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
  },
  "lsp": {
    "ruby-lsp": {
      // ruby は `mise env` 経由で ~/.config/ruby-lsp/mise.toml から、
      // gem は同ディレクトリの Gemfile（BUNDLE_GEMFILE）から解決する。
      "binary": {
        "path": "/bin/sh",
        "arguments": [
          "-c",
          "eval \"$(/opt/homebrew/bin/mise -C ~/.config/ruby-lsp env)\" && BUNDLE_GEMFILE=~/.config/ruby-lsp/Gemfile exec bundle exec ruby-lsp",
        ],
      },
      "initialization_options": {
        "indexing": {
          "excludedPatterns": ["**/feature-specs/**/*.rb"],
        },
      },
    },
  },
  "profiles": {
    "oxc": {
      "settings": {
        "languages": {
          "TypeScript": {
            "formatter": { "language_server": { "name": "oxfmt" } },
          },
          "TSX": { "formatter": { "language_server": { "name": "oxfmt" } } },
          "JavaScript": {
            "formatter": { "language_server": { "name": "oxfmt" } },
          },
        },
      },
    },
  },
}
